{
    "id": "image",
    "display_name": "Image Input",
    "description": "Loads an external image or Blender texture map.",
    "includes": [],
    "inputs": [
        { "name": "tex", "type": "sampler2D" }
    ],
    "outputs": [
        { "name": "color", "type": "vec4" }
    ],
    "params": [
        { "name": "u_offset", "default": 0.0, "min": -10.0, "max": 10.0, "step": 0.001 },
        { "name": "v_offset", "default": 0.0, "min": -10.0, "max": 10.0, "step": 0.001 },
        { "name": "u_scale",  "default": 1.0, "min": 0.001, "max": 10.0, "step": 0.001 },
        { "name": "v_scale",  "default": 1.0, "min": 0.001, "max": 10.0, "step": 0.001 }
    ],
    "shader": "image.glsl",
    "entry": "node_image"
}

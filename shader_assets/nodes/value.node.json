{
    "id": "value",
    "display_name": "Value Noise",
    "description": "Tileable value (lattice-scalar) FBM. Blockier than Perlin; ideal for clouds, organic blobs.",
    "includes": ["math_common", "noise_common"],
    "inputs": [],
    "outputs": [
        { "name": "color", "type": "vec4" }
    ],
    "params": [
        { "name": "period", "default": 8.0, "min": 1.0, "max": 64.0, "step": 1.0, "integer": true },
        { "name": "octaves", "default": 5.0, "min": 1.0, "max": 8.0, "step": 1.0, "integer": true },
        { "name": "lacunarity", "default": 2.0, "min": 1.0, "max": 4.0, "step": 0.01, "integer": true },
        { "name": "gain", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.01 },
        { "name": "offsetX", "default": 0.0, "min": -50.0, "max": 50.0, "step": 0.01 },
        { "name": "offsetY", "default": 0.0, "min": -50.0, "max": 50.0, "step": 0.01 },
        { "name": "speed", "default": 0.0, "min": 0.0, "max": 5.0, "step": 0.01 },
        { "name": "seed", "default": 0.0, "min": 0.0, "max": 65535.0, "step": 1.0, "integer": true }
    ],
    "shader": "value.glsl",
    "entry": "node_value",
    "format_sensitive": true,
    "pass_kind": "pure_pixel"
}

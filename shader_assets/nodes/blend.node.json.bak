{
    "id": "blend",
    "display_name": "Blend",
    "includes": ["color_common", "blend_common"],
    "inputs": [
        { "name": "mask", "type": "float", "default": 1.0 },
        { "name": "a", "type": "vec4" },
        { "name": "b", "type": "vec4" }
    ],
    "outputs": [
        { "name": "color", "type": "vec4" }
    ],
    "params": [
        { "name": "mode", "display_name": "Blend Mode",
          "description": "Combiner mode. Arithmetic modes (Add, Subtract, Multiply, Divide, ...) are HDR-unclamped; contrast modes (Overlay, Burn, Dodge, ...) self-bound to [0,1]. See blend.py for the enum mapping.",
          "default": 0.0, "min": 0.0, "max": 27.0, "step": 1.0, "integer": true }
    ],
    "shader": "blend.glsl",
    "entry": "node_blend"
}

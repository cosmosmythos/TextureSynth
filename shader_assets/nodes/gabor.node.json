{
    "id": "gabor",
    "display_name": "Gabor Noise",
    "description": "Anisotropic frequency-controlled noise. Ideal for wood, brushed metal, fabric.",
    "includes": ["remap", "noise_common"],
    "inputs": [],
    "outputs": [
        { "name": "color", "type": "vec4" }
    ],
    "params": [
        { "name": "period", "default": 8.0, "min": 1.0, "max": 64.0, "step": 1.0, "integer": true },
        { "name": "octaves", "default": 1.0, "min": 1.0, "max": 8.0, "step": 1.0, "integer": true },
        { "name": "lacunarity", "default": 2.0, "min": 1.0, "max": 4.0, "step": 1.0, "integer": true },
        { "name": "gain", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.01 },
        { "name": "frequency", "default": 8.0, "min": 1.0, "max": 32.0, "step": 0.1 },
        { "name": "bandwidth", "default": 2.0, "min": 0.5, "max": 8.0, "step": 0.1 },
        { "name": "anisotropy", "default": 0.0, "min": 0.0, "max": 1.0, "step": 0.01 },
        { "name": "angle", "default": 0.0, "min": 0.0, "max": 6.28318, "step": 0.001 },
        { "name": "offsetX", "default": 0.0, "min": -50.0, "max": 50.0, "step": 0.01 },
        { "name": "offsetY", "default": 0.0, "min": -50.0, "max": 50.0, "step": 0.01 },
        { "name": "speed", "default": 0.0, "min": 0.0, "max": 5.0, "step": 0.01 },
        { "name": "seed", "default": 0.0, "min": 0.0, "max": 65535.0, "step": 1.0, "integer": true }
    ],
    "shader": "gabor.glsl",
    "entry": "node_gabor",
    "format_sensitive": true,
    "pass_kind": "pure_pixel"
}

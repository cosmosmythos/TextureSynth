# Production build outputs.
build/
ADDON_OLDER/
out/
dist/
test_shader_cache/
*.whl
*.pyd
*.so
*.exp
*.lib
*.dll
*.egg-info/
*nul

# Local-only development artifacts (NOT shipped with the addon).
DEV_LOG/
*.bat
docs/
src/bindings/*.bak
opencode.json
*.lock

# Editor / IDE.
.vs/
.vscode/
*.user
CMakeUserPresets.json

# Python tooling (top-level only — test-local Python is in tests/.gitignore).
__pycache__/

# Shader assets: exclude dev/test/cache files.
shader_assets/**/*.bat
shader_assets/**/*.c
shader_assets/**/glslViewer_tests/
shader_cache/
shader_assets/**/format_nodes.py
shader_assets/**/README.md

# ImGui persists UI layout to this file.
imgui.ini

# Stray diagnostic dumps (must never be committed).
diag_engine.txt

# ctest drops a Testing/ dir at CWD when run with --test-dir; never commit it.
/Testing/

tuxalin/
vendor/GLSL/
